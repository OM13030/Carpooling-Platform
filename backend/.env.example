# Server Configuration
PORT=5000

# Database Connection
MONGODB_URI=mongodb://localhost:27017/carpool_db

# JWT Secrets & Configuration
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Maps API (GraphHopper)
GRAPHHOPPER_API_KEY=your_graphhopper_api_key_here

# Frontend Application Client URL
CLIENT_URL=http://localhost:5173

# Uber Integration Credentials (Phase 1 Deep-Link / Phase 2 OAuth estimates)
UBER_CLIENT_ID=your_uber_client_id_here
UBER_CLIENT_SECRET=your_uber_client_secret_here
UBER_REDIRECT_URI=http://localhost:5000/api/uber/callback

